# ============ DATABASE ============
# Neon PostgreSQL (production): https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/englishup?sslmode=require

# Direct connection (for migrations, bypasses connection pooler)
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/englishup?sslmode=require

# ============ JWT ============
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# ============ OAUTH - GOOGLE ============
# Lấy tại: https://console.developers.google.com
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_CALLBACK_URL=https://your-api.vercel.app/api/auth/google/callback

# ============ OAUTH - FACEBOOK ============
# Lấy tại: https://developers.facebook.com
FACEBOOK_APP_ID=xxx
FACEBOOK_APP_SECRET=xxx
FACEBOOK_CALLBACK_URL=https://your-api.vercel.app/api/auth/facebook/callback

# ============ APP ============
PORT=3000
NODE_ENV=development

# URL của Frontend (Angular app)
FRONTEND_URL=http://localhost:4200

# ============ ADMIN SEED ============
ADMIN_EMAIL=admin@englishup.com
ADMIN_PASSWORD=Admin@123456
